# SV-COMP reachability-verifier evaluation of the cir2c-mapped suite.
#
# Everything is auto-detected: each xml/<tool>.xml (generated by gen-xml.py from
# fm-tools) becomes a downloadable, runnable tool. Adding/removing a tool is just
# adding/removing an XML — no edit here. The ONE tool-specific fact, "esbmc-kind,
# cbmc and divine also verify the original C++ suite (three configs)", lives in
# gen-xml.py and is re-derived below from which configs each XML declares.
#
# Quickstart:
#   make SETS=smoke esbmc-kind        # link smoke set, fetch+run one tool
#   make SETS=full all -j8            # link full set, run every tool in parallel
#   make tables                       # normalize results and build comparison tables

# SV-COMP CPU-time limit (the 15 GB / 8-core limits live in the XMLs).
TIMEOUT  ?= 900s
# Task set selector: must be set explicitly (smoke|full) — there is no default,
# so a run never silently uses the wrong set. `sets` is symlinked accordingly.
SETS     ?= none
# Reference verifier whose original-suite (esbmc-eval) column anchors the
# esbmc-vs-<tool> tables.
BASELINE ?= esbmc-kind

# Runs are launched from inside the tool's own directory (tools/bin/<tool>) so the
# verifier binary is the working directory and is found there without
# --tool-directory. UP is the path from a tool dir back up to here; -o keeps
# results in $(RESULTS_DIR) despite the cwd, and the XML's own includes/properties
# stay anchored to xml/.
UP      = ../../..

WORKING_DIR ?= $(shell pwd)

# Benchmark runner: 'benchexec' (local, the default) or 'vcloud' (VerifierCloud).
RUNNER ?= benchexec

# Flags accepted by both runners.
COMMON_FLAGS = --read-only-dir=/ --hidden-dir=/home --overlay-dir=$(WORKING_DIR) --timelimit $(TIMEOUT) -o $(UP)/$(RESULTS_DIR)/
# VerifierCloud-only flags (priority/scheduling, client heap, ivy cache); plain
# benchexec rejects these, so they are added only when RUNNER=vcloud.
# --vcloudAdditionalFiles . ships each tool's whole directory to the worker, which
# covers files a tool-info module's program_files() omits (e.g. divine4.py invokes
# the divine-svc wrapper but never declares it, so without this it isn't shipped).
# It takes nargs="*", so it must be followed by another flag (--no-ivy-cache here),
# never by the trailing XML path, or it would swallow the benchmark definition.
VCLOUD_FLAGS = --vcloudPriority HIGH --tryLessMemory --vcloudClientHeap 4000 --vcloudAdditionalFiles . --no-ivy-cache

ifeq ($(RUNNER),vcloud)
  RUNNER_BIN = $(UP)/benchexec/contrib/vcloud-benchmark.py
  FLAGS      = $(COMMON_FLAGS) $(VCLOUD_FLAGS)
else ifeq ($(RUNNER),benchexec)
  RUNNER_BIN = $(UP)/benchexec/bin/benchexec
  FLAGS      = $(COMMON_FLAGS)
else
  $(error RUNNER must be 'benchexec' or 'vcloud', got '$(RUNNER)')
endif

CURL      = curl -L --fail --retry 5 --retry-all-errors
TOOLS_BIN = tools/bin

# ── Auto-detected tool set ───────────────────────────────────────────────────
# Every tool with an XML.
ALL_TOOLS   := $(patsubst xml/%.xml,%,$(wildcard xml/*.xml))
# Tools whose XML declares the original-suite config (esbmc-eval): the three
# C++-capable verifiers that run all three configs. Re-derived from the XMLs so
# the Makefile itself hardcodes no tool names.
CXX_TOOLS   := $(patsubst xml/%.xml,%,$(shell grep -lF 'name="esbmc-eval"' xml/*.xml 2>/dev/null))
# Everything else: C-only, two mapped configs, compared against the baseline.
OTHER_TOOLS := $(filter-out $(CXX_TOOLS),$(ALL_TOOLS))

# Post-processing layout (unchanged).
RESULTS_DIR ?= results
NORM_DIR     = $(RESULTS_DIR)/normalized
TABLES_DIR  ?= tables
TABLE_GEN    = PYTHONPATH=./benchexec ./benchexec/bin/table-generator

.PHONY: all list download-all normalize tables link-sets $(ALL_TOOLS)

# Run every detected tool. Independent, so `make all -j8` parallelises them.
all: $(ALL_TOOLS)

list:
	@echo "all tools   ($(words $(ALL_TOOLS))): $(ALL_TOOLS)"
	@echo "three-config ($(words $(CXX_TOOLS))): $(CXX_TOOLS)"
	@echo "two-config   ($(words $(OTHER_TOOLS))): $(OTHER_TOOLS)"

# ── Task-set selection ───────────────────────────────────────────────────────
# Link sets/ -> sets-smoke/ or sets-full/ based on SETS (no default: explicit).
link-sets:
	@case "$(SETS)" in \
	  smoke) ln -sfn sets-smoke sets ;; \
	  full)  ln -sfn sets-full  sets ;; \
	  *) echo "error: set SETS=smoke or SETS=full (got '$(SETS)')" >&2; exit 1 ;; \
	esac

# ── Tool download ────────────────────────────────────────────────────────────
# Resolve the tool's archive URL from fm-tools, fetch, unzip, and install at
# $(TOOLS_BIN)/<tool>: if the archive has a single top-level directory, rename it
# to the tool name; otherwise put the loose contents into a new tool-named dir.
# Order-only prerequisite below means this fires once, only when the dir is absent.
download-all: $(addprefix $(TOOLS_BIN)/,$(ALL_TOOLS))

# fm-tools (the SV-COMP tool database) is gitignored, so clone it on demand.
# The URL/logic live in _fmtools.py; this target just triggers the clone.
tools/fm-tools:
	python3 -c "import _fmtools; _fmtools.ensure_fm_tools()"

$(TOOLS_BIN)/%: | tools/fm-tools
	@set -e; echo ">> downloading $* ..."; \
	url=$$(python3 fmtools-url.py $*); \
	tmp=$$(mktemp -d); trap 'rm -rf "$$tmp"' EXIT; \
	$(CURL) -o "$$tmp/archive.zip" "$$url"; \
	mkdir -p "$$tmp/unz"; unzip -q "$$tmp/archive.zip" -d "$$tmp/unz"; \
	mkdir -p $(TOOLS_BIN); \
	count=$$(find "$$tmp/unz" -mindepth 1 -maxdepth 1 | wc -l); \
	first=$$(find "$$tmp/unz" -mindepth 1 -maxdepth 1); \
	if [ "$$count" -eq 1 ] && [ -d "$$first" ]; then \
	  mv "$$first" "$(TOOLS_BIN)/$*"; \
	else \
	  mkdir -p "$(TOOLS_BIN)/$*"; mv "$$tmp/unz"/* "$(TOOLS_BIN)/$*/"; \
	fi; \
	echo ">> installed $(TOOLS_BIN)/$*"

# ── Tool runs ────────────────────────────────────────────────────────────────
# `make <tool>` downloads if needed, links sets/, then runs from inside the tool
# directory so the binary and arguments are found relative to it. The XML's own
# includes/properties stay anchored to xml/, so they still resolve to ../sets etc.
$(ALL_TOOLS): %: | $(TOOLS_BIN)/% link-sets
	cd $(TOOLS_BIN)/$* && $(RUNNER_BIN) $(FLAGS) $(UP)/xml/$*.xml

# ── Post-processing ──────────────────────────────────────────────────────────
# Strip ../sources/<variant>/ from run names so each benchmark matches across
# source sets when table-generator joins columns.
normalize:
	python3 normalize-results.py $(RESULTS_DIR)/*.xml.bz2
	-cp $(RESULTS_DIR)/*.logfiles.zip $(NORM_DIR)/ 2>/dev/null

# ── Tables ───────────────────────────────────────────────────────────────────
# Auto-generated, one per tool:
#   <tool>-all      for each three-config tool: its three configs side by side.
#   esbmc-vs-<tool> for each two-config tool: ESBMC baseline (original) vs the
#                   tool on the mapped and mapped-nostd variants.
tables: normalize
	@mkdir -p $(TABLES_DIR)
	@for t in $(CXX_TOOLS); do \
	  echo ">> table $$t-all"; \
	  $(TABLE_GEN) -o $(TABLES_DIR)/$$t-all \
	    $(NORM_DIR)/$$t.*.results.esbmc-eval.esbmc-eval.xml.bz2 \
	    $(NORM_DIR)/$$t.*.results.esbmc-eval-mapped.esbmc-eval-mapped.xml.bz2 \
	    $(NORM_DIR)/$$t.*.results.esbmc-eval-mapped-nostd.esbmc-eval-mapped-nostd.xml.bz2 \
	    || echo "   (skipped $$t-all: missing results)"; \
	done
	@for t in $(OTHER_TOOLS); do \
	  echo ">> table esbmc-vs-$$t"; \
	  $(TABLE_GEN) -o $(TABLES_DIR)/esbmc-vs-$$t \
	    $(NORM_DIR)/$(BASELINE).*.results.esbmc-eval.esbmc-eval.xml.bz2 \
	    $(NORM_DIR)/$$t.*.results.esbmc-eval-mapped.esbmc-eval-mapped.xml.bz2 \
	    $(NORM_DIR)/$$t.*.results.esbmc-eval-mapped-nostd.esbmc-eval-mapped-nostd.xml.bz2 \
	    || echo "   (skipped esbmc-vs-$$t: missing results)"; \
	done
